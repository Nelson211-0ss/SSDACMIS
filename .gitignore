.env
.DS_Store
Thumbs.db
storage/logs/*
!storage/logs/.gitkeep
storage/uploads/*
!storage/uploads/.gitkeep
public/uploads/*
!public/uploads/.gitkeep
!public/uploads/.htaccess
# Keep the student-photo folder in the repo so it always exists after a
