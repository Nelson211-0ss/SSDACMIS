APP_NAME="SSD-ACMIS — School Management System"
APP_ENV=local
APP_DEBUG=true
# Folder name in htdocs (case-sensitive on Linux). Default ships as SSDACMIS;
# older clones may still be named schoolreg — both work since the runtime
# detects the install path automatically.
APP_URL=http://localhost/SSDACMIS/public
APP_TZ=Africa/Nairobi
APP_KEY=change-me-to-a-long-random-string

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Database name — independent of the project folder name. Pick whatever
# you created in MySQL. Existing installs may use 'schoolreg'.
DB_NAME=ssdacmis
DB_USER=root
DB_PASS=

# Session cookie name — also independent of folder/DB names.
SESSION_NAME=ssdacmis_sid
SESSION_LIFETIME=7200
